{
  "$schema": "https://superzhao.dev/schemas/skill-lab/v3/meta.schema.json",
  "$id": "https://superzhao.dev/schemas/skill-lab/v3/bundle-manifest.schema.json",
  "title": "Superzhao Skill Lab v3 bundle manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "campaign_id",
    "proposal_id",
    "producer",
    "entrypoints",
    "artifacts",
    "files"
  ],
  "properties": {
    "schema": {
      "const": "superzhao.skill-lab.bundle-manifest/v3"
    },
    "campaign_id": {
      "$ref": "#/$defs/stableId"
    },
    "proposal_id": {
      "$ref": "#/$defs/stableId"
    },
    "producer": {
      "$ref": "#/$defs/producer"
    },
    "entrypoints": {
      "$ref": "#/$defs/entrypoints"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/artifactMapping"
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/file"
      }
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "path": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:/)(?!.*//)(?!.*(?:^|/)(?:\\.{1,2})(?:/|$))(?!.*\\\\)(?!.*[\\u0000-\\u001f\\u007f])[^/]+(?:/[^/]+)*$"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_id",
        "plugin_version",
        "cli_sha256",
        "node_version",
        "platform",
        "arch"
      ],
      "properties": {
        "plugin_id": {
          "const": "superzhao-skill-lab"
        },
        "plugin_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
        },
        "cli_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "node_version": {
          "type": "string",
          "pattern": "^v?(?:20|22)\\.[0-9]+\\.[0-9]+$"
        },
        "platform": {
          "enum": ["darwin", "linux"]
        },
        "arch": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        }
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "candidate",
        "patch",
        "cases",
        "samples",
        "apply_report",
        "gate_report",
        "producer_cli"
      ],
      "properties": {
        "source": {
          "$ref": "#/$defs/path"
        },
        "candidate": {
          "$ref": "#/$defs/path"
        },
        "patch": {
          "$ref": "#/$defs/path"
        },
        "cases": {
          "$ref": "#/$defs/path"
        },
        "samples": {
          "$ref": "#/$defs/path"
        },
        "apply_report": {
          "$ref": "#/$defs/path"
        },
        "gate_report": {
          "$ref": "#/$defs/path"
        },
        "producer_cli": {
          "$ref": "#/$defs/path"
        }
      }
    },
    "artifactMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "packaged_path", "sha256"],
      "properties": {
        "kind": {
          "enum": [
            "source-skill",
            "candidate-skill",
            "patch",
            "cases",
            "samples",
            "actor-run",
            "scorer-record",
            "apply-report",
            "gate-report",
            "prior-rejection",
            "prompt",
            "rubric",
            "environment",
            "actor-profile",
            "scorer-profile",
            "harness-model-profile",
            "transcript",
            "scorer-output",
            "producer-cli"
          ]
        },
        "source_path": {
          "$ref": "#/$defs/path"
        },
        "packaged_path": {
          "$ref": "#/$defs/path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "if": {
        "required": ["kind"],
        "properties": {
          "kind": {
            "const": "producer-cli"
          }
        }
      },
      "then": {
        "not": {
          "required": ["source_path"]
        }
      },
      "else": {
        "required": ["source_path"]
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes"],
      "properties": {
        "path": {
          "$ref": "#/$defs/path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100663296
        }
      }
    }
  }
}
