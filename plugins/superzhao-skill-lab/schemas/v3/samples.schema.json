{
  "$schema": "https://superzhao.dev/schemas/skill-lab/v3/meta.schema.json",
  "$id": "https://superzhao.dev/schemas/skill-lab/v3/samples.schema.json",
  "title": "Superzhao Skill Lab v3 sample ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "campaign_id",
    "source",
    "candidate",
    "cases",
    "samples"
  ],
  "properties": {
    "schema": {
      "const": "superzhao.skill-lab.samples/v3"
    },
    "campaign_id": {
      "$ref": "#/$defs/stableId"
    },
    "source": {
      "$ref": "#/$defs/artifact"
    },
    "candidate": {
      "$ref": "#/$defs/artifact"
    },
    "cases": {
      "$ref": "#/$defs/artifact"
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/sample"
      }
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "failureCode": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "path": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:/)(?!.*//)(?!.*(?:^|/)(?:\\.{1,2})(?:/|$))(?!.*\\\\)(?!.*[\\u0000-\\u001f\\u007f])[^/]+(?:/[^/]+)*$"
    },
    "nonBlank": {
      "type": "string",
      "pattern": "\\S"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "$ref": "#/$defs/path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_id",
        "run_id",
        "actor_instance_id",
        "actor_profile_id",
        "case_id",
        "split",
        "case_type",
        "arm",
        "skill_sha256",
        "status"
      ],
      "properties": {
        "sample_id": {
          "$ref": "#/$defs/stableId"
        },
        "run_id": {
          "$ref": "#/$defs/stableId"
        },
        "actor_instance_id": {
          "$ref": "#/$defs/stableId"
        },
        "actor_profile_id": {
          "$ref": "#/$defs/stableId"
        },
        "case_id": {
          "$ref": "#/$defs/stableId"
        },
        "split": {
          "enum": ["train", "selection", "test"]
        },
        "case_type": {
          "enum": ["important", "control"]
        },
        "arm": {
          "enum": ["current", "candidate"]
        },
        "skill_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "actor_run": {
          "$ref": "#/$defs/artifact"
        },
        "scorer_run_id": {
          "$ref": "#/$defs/stableId"
        },
        "scorer_record": {
          "$ref": "#/$defs/artifact"
        },
        "status": {
          "enum": ["valid", "invalid", "indeterminate"]
        },
        "outcome": {
          "enum": ["pass", "fail"]
        },
        "failure_code": {
          "$ref": "#/$defs/failureCode"
        },
        "reason": {
          "$ref": "#/$defs/nonBlank"
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["status"],
            "properties": {
              "status": {
                "const": "valid"
              }
            }
          },
          "then": {
            "required": ["actor_run", "scorer_run_id", "scorer_record", "outcome"],
            "not": {
              "required": ["reason"]
            },
            "allOf": [
              {
                "if": {
                  "required": ["outcome"],
                  "properties": {
                    "outcome": {
                      "const": "fail"
                    }
                  }
                },
                "then": {
                  "required": ["failure_code"]
                }
              },
              {
                "if": {
                  "required": ["outcome"],
                  "properties": {
                    "outcome": {
                      "const": "pass"
                    }
                  }
                },
                "then": {
                  "not": {
                    "required": ["failure_code"]
                  }
                }
              }
            ]
          },
          "else": {
            "required": ["reason"],
            "not": {
              "anyOf": [
                {
                  "required": ["outcome"]
                },
                {
                  "required": ["failure_code"]
                }
              ]
            }
          }
        }
      ]
    }
  }
}
